								},
								async cost(event, trigger, player) {
									event.result = await player
										.chooseCardTarget({
											prompt: get.prompt2(event.skill),
											filterCard: true,
											position: "he",
											filterTarget(card, player, target) {
												return target.canAddJudge("shandian");
